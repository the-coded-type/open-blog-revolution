---
const { queryFilters, heading, nbPosts, sectionHeaderContentClass } = Astro.props;

import QueryPosts from '@posts/query-posts.astro';

import { CONFIG } from "@config";

import PostFooterText from "@data/post-footer.mdx"


---
<footer class="article-footer mt-lg">
    <PostFooterText />
    {CONFIG.POST_THUMBNAILS &&
        <QueryPosts queryFilters={queryFilters} heading={heading} nbPosts={nbPosts} sectionHeaderContentClass={sectionHeaderContentClass}  />
    }
</footer>