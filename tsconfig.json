{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*", "src/types/**/*.d.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@posts/*": ["src/components/posts/*"],
      "@config": ["src/lib/load-config.ts"],
      "@media": ["src/media/*"], 
      "@data": ["src/data/*"], 
    }
  }
}
